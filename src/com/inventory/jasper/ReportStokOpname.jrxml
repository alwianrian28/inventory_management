	<subDataset name="StokOpnameDetail" uuid="55523f0f-d712-45b5-b233-a4cf65455939">
		<parameter name="opnameID" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[SELECT st.stok_id, b.barang_name, det.stok_sistem, det.stok_fisik, det.selisih, det.catatan
				FROM stok_opname_detail det
				INNER JOIN stok_opname so ON so.opname_id = det.opname_id
				INNER JOIN barang b ON b.barang_id = det.barang_id
				INNER JOIN stok_gudang st ON st.stok_id = det.stok_id
				WHERE so.opname_id = $P{opnameID} AND st.jumlah > 0 AND st.harga_beli > 0 AND b.harga_jual > 0 AND b.stok_minimum > 0
				GROUP BY st.stok_id, b.barang_name]]>
		</queryString>
		<field name="stok_id" class="java.lang.Integer">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="barang_name" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="stok_sistem" class="java.lang.Integer">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="stok_fisik" class="java.lang.Integer">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="selisih" class="java.lang.Integer">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="catatan" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
	</subDataset>
	<parameter name="REPORT_FORMAT" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="name" class="java.lang.String"/>
	<parameter name="role" class="java.lang.String"/>
	<parameter name="startDate" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="endDate" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="LOGO_IMAGE" class="java.awt.Image"/>
	<queryString>
		<![CDATA[SELECT so.opname_id, so.tanggal_opname, so.keterangan, so.status
			from stok_opname so
			inner join stok_opname_detail det on so.opname_id = det.opname_id
			inner join barang b on b.barang_id = det.barang_id
			inner join stok_gudang st on st.stok_id = det.stok_id
			inner join satuan s on s.satuan_id = b.satuan_id
			inner join rak r on r.rak_id = st.rak_id
			inner join gudang g on g.gudang_id = st.gudang_id
			WHERE so.tanggal_opname BETWEEN $P{startDate} AND $P{endDate}
			GROUP BY so.opname_id, so.tanggal_opname, so.keterangan, so.status, b.barang_name, s.satuan_name, r.rak_name, g.gudang_name]]]>
	</queryString>
