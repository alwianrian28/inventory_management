	<queryString>
		<![CDATA[SELECT 	st.stok_id,
			b.barang_code, 
			b.barang_name, 
			st.harga_beli,	
			b.harga_jual, 
			b.stok_minimum, 
			st.jumlah, 
			m.merk_name, 
			k.kategori_name, 
			s.satuan_name, 
			sp.supplier_name, 
			r.rak_name, 
			g.gudang_name
			from stok_gudang st
			inner join barang b ON b.barang_id = st.barang_id
			inner join merk m ON b.merk_id = m.merk_id
			inner join kategori k ON b.kategori_id = k.kategori_id
			inner join satuan s ON b.satuan_id = s.satuan_id
			inner join supplier sp ON b.supplier_id = sp.supplier_id
			inner join rak r ON r.rak_id = st.rak_id
			inner join gudang g ON g.gudang_id = st.gudang_id
			WHERE b.is_delete = 0 AND st.jumlah > 0 AND st.harga_beli > 0 AND b.harga_jual > 0 AND b.stok_minimum > 0
			GROUP BY st.stok_id, b.barang_code, b.barang_name, st.harga_beli, b.harga_jual, b.stok_minimum, st.jumlah, m.merk_name, k.kategori_name, s.satuan_name, sp.supplier_name, r.rak_name, g.gudang_name]]>
	</queryString>
