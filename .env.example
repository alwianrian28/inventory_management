# Salin ke .env lalu sesuaikan: cp .env.example .env
#
# MySQL di Docker (ganti brew services):
#   brew services stop mysql
#   docker compose up -d
#   docker compose ps
#
# NetBeans / run app: set DB_* di bawah atau di Environment Variables IDE.

MYSQL_ROOT_PASSWORD=inventory_root
MYSQL_DATABASE=inventory_management
MYSQL_PORT=3307

DB_HOST=localhost
DB_PORT=3307
DB_NAME=inventory_management
DB_USER=root
DB_PASSWORD=inventory_root
